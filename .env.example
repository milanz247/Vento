# Vento environment configuration.
# Copy this file to .env and fill in real values for your machine:
#   cp .env.example .env
# .env is gitignored - never commit real credentials.

# --- Application ---
# Port the HTTP server listens on.
PORT=8080

# Signing secret for vento.Sessions (cookie-based sessions). Leave blank to
# run without sessions; set it to enable them - a long random string, kept
# stable across restarts (changing it invalidates every existing session).
# Generate one with: openssl rand -hex 32
APP_KEY=

# --- Database (MySQL is the only supported provider) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=vento_app
